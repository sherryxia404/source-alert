# Five minutes. The program rejects intervals shorter than 60 seconds.
CHECK_INTERVAL_SECONDS=300
DATABASE_PATH=data/source_alert.sqlite3
SOURCES_FILE=sources.yaml
LOG_LEVEL=INFO

# Easiest phone notification option:
# 1. Install the ntfy app.
# 2. Choose a long, private, hard-to-guess topic name.
# 3. Subscribe to that exact topic in the app.
NTFY_SERVER=https://ntfy.sh
NTFY_TOPIC=

# Optional alternative: Telegram bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
